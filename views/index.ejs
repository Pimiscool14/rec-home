<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <h1 class="hero-title">
      Welcome to <span class="gradient-text">Rec Home</span>
    </h1>
    <p class="hero-subtitle">
      Play Rec Room on your own terms. Create an account, launch the game, and join the fun.
    </p>
    <div class="hero-actions">
      <a href="/auth/register" class="btn btn-primary btn-lg">Create Account</a>
      <a href="/auth/login" class="btn btn-secondary btn-lg">Sign In</a>
    </div>
  </div>
</div>

<section class="section">
  <h2 class="section-title">How It Works</h2>
  <div class="install-steps">
    <div class="install-step">
      <div class="step-number">1</div>
      <div class="step-content">
        <h3>Create Your Account</h3>
        <p>Sign up with your email and username. No Discord required — just pick a name and password.</p>
      </div>
    </div>
    <div class="install-step">
      <div class="step-number">2</div>
      <div class="step-content">
        <h3>Launch the Game</h3>
        <p>Make sure Steam is running, then double-click <strong>Play Rec Room.bat</strong> to start the game with all features enabled.</p>
      </div>
    </div>
    <div class="install-step">
      <div class="step-number">3</div>
      <div class="step-content">
        <h3>Play & Explore</h3>
        <p>Join rooms, complete quests, play paintball, build creations, or just hang out with friends.</p>
      </div>
    </div>
  </div>
</section>

<section class="section cta-section">
  <div class="cta-content">
    <h2>Ready to play?</h2>
    <p>Create your free Rec Home account and get started.</p>
    <a href="/auth/register" class="btn btn-primary btn-lg">Create Account</a>
  </div>
</section>
