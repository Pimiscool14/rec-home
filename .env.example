# Server
PORT=3000
NODE_ENV=production

# Session & JWT Secrets (REQUIRED - use strong random strings)
SESSION_SECRET=your-random-session-secret-here
JWT_SECRET=your-random-jwt-secret-here

# Database (leave blank to use default: ./database/rec-home.db)
# DATABASE_PATH=

# Discord OAuth (optional)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=
